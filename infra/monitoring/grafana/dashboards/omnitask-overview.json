{
  "title": "OmniTask Overview",
  "uid": "omnitask-overview",
  "version": 1,
  "tags": ["omnitask", "production"],
  "schemaVersion": 39,
  "panels": [
    {
      "title": "HTTP Requests - Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(omnitask_http_requests_total[5m])",
          "legendFormat": "{{method}} {{route}}",
          "interval": "15s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "title": "HTTP Request Duration - P95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(omnitask_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{method}} {{route}}",
          "interval": "15s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "title": "Active WebSocket Connections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "omnitask_active_connections",
          "legendFormat": "connections",
          "interval": "15s"
        }
      ]
    },
    {
      "title": "Queue Depth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "omnitask_queue_depth",
          "legendFormat": "{{queue}}",
          "interval": "15s"
        }
      ]
    },
    {
      "title": "DB Query Duration - P95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(omnitask_db_query_duration_seconds_bucket[5m]))",
          "legendFormat": "{{query}}",
          "interval": "15s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(omnitask_http_requests_total{status=~\"5..\"}[5m]) / rate(omnitask_http_requests_total[5m])",
          "legendFormat": "error rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "title": "Resource Usage - Memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "memory"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      }
    }
  ]
}
