# Environment Configuration
# Copy this file to .env and fill in your values

# User Information
USER_NAME="Your Full Name"
USER_EMAIL="your.email@example.com"
USER_PHONE="+91-XXXXXXXXXX"

# LLM Configuration (GitHub Copilot or other)
# If using GitHub Copilot API (when available)
GITHUB_TOKEN="your_github_token_here"
LLM_MODEL="claude-sonnet-4.5"  # Options: claude-sonnet-4.5, gpt-5.1, etc.

# Application Limits
MAX_APPLICATIONS_PER_DAY=20
MAX_APPLICATIONS_PER_PORTAL=5

# Browser Configuration
HEADLESS=false  # Set to true for headless mode
BROWSER_SLOW_MO=500  # Milliseconds to slow down browser actions

# Portal Credentials (Optional - for auto-login if needed)
NAUKRI_EMAIL=""
NAUKRI_PASSWORD=""
INSTAHYRE_EMAIL=""
INSTAHYRE_PASSWORD=""
HIRIST_EMAIL=""
HIRIST_PASSWORD=""
LINKEDIN_EMAIL=""
LINKEDIN_PASSWORD=""

# Debug Mode
DEBUG=true
DRY_RUN=false  # If true, won't actually submit applications
