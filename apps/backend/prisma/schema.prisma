generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum UserRole { USER ADMIN }
enum TaskStatus { QUEUED PLANNING RUNNING PAUSED FAILED DONE CANCELLED }
enum ApprovalStatus { PENDING APPROVED DENIED EXPIRED }
enum AgentType { BROWSER API FILE RESEARCH SUPERVISOR }

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  passwordHash     String?
  refreshTokenHash String?
  role             UserRole  @default(USER)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tasks            Task[]
  files            File[]
  memories         Memory[]
  skills           Skill[]
  schedules        Schedule[]
  policies         Policy[]
  @@index([email])
}

model Task {
  id          String     @id @default(cuid())
  userId      String
  rawInput    String
  planHash    String?
  plan        Json?
  status      TaskStatus @default(QUEUED)
  shadowMode  Boolean    @default(false)
  errorMessage String?
  startedAt   DateTime?
  completedAt DateTime?
  metadata    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps       Step[]
  approvals   Approval[]
  files       File[]
  @@index([userId, status])
  @@index([createdAt])
}

model Step {
  id            String   @id @default(cuid())
  taskId        String
  index         Int
  action        String
  input         Json?
  result        Json?
  screenshotUrl String?
  domSnapshotUrl String?
  duration      Int?
  error         String?
  executedAt    DateTime?
  createdAt     DateTime @default(now())
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  @@index([taskId, index])
}

model Approval {
  id          String         @id @default(cuid())
  taskId      String
  stepIndex   Int
  reason      String
  screenshot  String?
  status      ApprovalStatus @default(PENDING)
  resolvedAt  DateTime?
  resolvedBy  String?
  expiresAt   DateTime
  createdAt   DateTime       @default(now())
  task        Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  @@index([taskId, status])
}

model File {
  id          String   @id @default(cuid())
  userId      String
  taskId      String?
  originalName String
  s3Key       String   @unique
  mimeType    String
  sizeBytes   Int
  url         String?
  embedding   Unsupported("vector(1536)")?
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([taskId])
}

model Memory {
  id        String   @id @default(cuid())
  userId    String
  content   String
  plan      Json
  embedding Unsupported("vector(1536)")
  useCount  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Skill {
  id           String   @id @default(cuid())
  userId       String
  name         String
  description  String?
  planTemplate Json
  successCount Int      @default(0)
  failCount    Int      @default(0)
  confidence   Float    @default(0)
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, isActive])
}

model Schedule {
  id           String   @id @default(cuid())
  userId       String
  name         String
  cronExpr     String
  taskTemplate Json
  isActive     Boolean  @default(true)
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  runCount     Int      @default(0)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Policy {
  id        String   @id @default(cuid())
  userId    String
  domain    String
  action    String
  allow     Boolean  @default(true)
  requireApproval Boolean @default(false)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, domain, action])
}