# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
API_PREFIX=api

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_minimum_32_char_random_string_now
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another_different_32_char_random_string_here
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ── Database ─────────────────────────────────────────────────────
POSTGRES_USER=omnitask
POSTGRES_PASSWORD=omnitask_secret
POSTGRES_DB=omnitask
DATABASE_URL=postgresql://omnitask:omnitask_secret@localhost:5432/omnitask?schema=public

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Storage (MinIO) ──────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=omnitask-files
S3_REGION=us-east-1
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Email (optional phase 1) ─────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@omnitask.ai

# ── Worker ───────────────────────────────────────────────────────
WORKER_CONCURRENCY=3

# ── MFA ──────────────────────────────────────────────────────────
MFA_APP_NAME=OmniTask