# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=production
PORT=3000

# ============================================================
# FRONTEND
# ============================================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com

# ============================================================
# BACKEND
# ============================================================
API_PORT=4000

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql://postgres:your-secure-password@postgres:5432/omnitask
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=omnitask

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://:your-redis-password@redis:6379
REDIS_PASSWORD=your-redis-password
# Host/port form used by the Bull queues, worker-event relay, Python engine bridge:
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================
# BROWSER ENGINE (live execution)
# ============================================================
# python = Playwright Python engine (apps/browser-py) — default
# node   = legacy BullMQ Puppeteer worker (apps/worker)
# inline = in-process Puppeteer in the API (fallback)
BROWSER_RUNTIME=python
# Headful by default (visible window → trustworthy live view, lower bot detection).
# Set to 'true' ONLY on headless servers/CI (run under xvfb there).
PLAYWRIGHT_HEADLESS=false
PY_STREAM_QUALITY=60
# Console verbosity for the Python engine. Quiet by default — watch runs in the
# dashboard live view, not the terminal. Set to INFO or DEBUG to restore output.
BROWSER_PY_LOG_LEVEL=WARNING
# Where per-user persistent Chromium profiles live (cookies/sessions survive
# restarts → stay logged in). One isolated folder per user. Default:
# apps/browser-py/profiles/. Keep this OUT of version control.
# BROWSER_PROFILES_DIR=./apps/browser-py/profiles
# --- Profile garbage collection / quota (set any to 0 to disable) ---
# Per-user disk cap (MB): over this, regenerable CACHES are trimmed — the user
# stays logged in (cookies/sessions are never deleted by the quota).
BROWSER_PROFILE_MAX_MB=750
# Close a user's in-memory browser after this many idle seconds (frees the
# process; on-disk profile keeps the login, next run relaunches logged-in).
BROWSER_CONTEXT_IDLE_S=1800
# How often the background GC runs (seconds). 0 disables GC entirely.
BROWSER_GC_INTERVAL_S=1800
# Hard-delete profiles untouched for this many days. This LOGS THEM OUT, so it's
# off by default. Set e.g. 30 to reclaim full space from long-abandoned users.
BROWSER_PROFILE_TTL_DAYS=0
# Max automatic crash-recovery relaunches per run. On a renderer crash mid-run,
# the engine relaunches a page in the same logged-in profile and retries the
# failed step. 0 disables auto-recovery (a crash fails the run as before).
BROWSER_MAX_RECOVERIES=2

# ============================================================
# JOB APPLICATION AGENT (apps/browser-py — job_application skill)
# ============================================================
# Dry-run (default true): search, match, and fill forms, but DO NOT click the
# final submit. Set to false to send real applications. The dashboard wizard's
# dry-run toggle overrides this per run.
JOB_AGENT_DRY_RUN=true
# Approval gate. false (default) → each submit waits for your Approve click in
# the dashboard. true → fully automatic, no prompt (only matters when DRY_RUN=false).
JOB_AGENT_AUTO_APPROVE=false
# How long a submit waits for approval before being skipped (milliseconds).
JOB_AGENT_APPROVAL_TIMEOUT_MS=300000
# Job-agent console verbosity. ERROR (default) keeps the terminal clean; the run
# is still fully visible in the dashboard. Set INFO/DEBUG to trace in the console.
JOB_AGENT_LOG_LEVEL=ERROR

# ============================================================
# JWT SECRETS
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# ============================================================
# AI SERVICES
# ============================================================
OPENAI_API_KEY=sk-proj-xxx
FRONTEND_URL=http://localhost:3000
ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================================
# GOOGLE OAUTH (Sign in with Google)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly.
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ============================================================
# EMAIL (Optional)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ============================================================
# MONITORING (Optional)
# ============================================================
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx