# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=production
PORT=3000

# ============================================================
# FRONTEND
# ============================================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com

# ============================================================
# BACKEND
# ============================================================
API_PORT=4000

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql://postgres:your-secure-password@postgres:5432/omnitask
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=omnitask

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://:your-redis-password@redis:6379
REDIS_PASSWORD=your-redis-password
# Host/port form used by the Bull queues, worker-event relay, Python engine bridge:
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================
# BROWSER ENGINE (live execution)
# ============================================================
# python = Playwright Python engine (apps/browser-py) — default
# node   = legacy BullMQ Puppeteer worker (apps/worker)
# inline = in-process Puppeteer in the API (fallback)
BROWSER_RUNTIME=python
# Headful by default (visible window → trustworthy live view, lower bot detection).
# Set to 'true' ONLY on headless servers/CI (run under xvfb there).
PLAYWRIGHT_HEADLESS=false
PY_STREAM_QUALITY=60

# ============================================================
# JWT SECRETS
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# ============================================================
# AI SERVICES
# ============================================================
OPENAI_API_KEY=sk-proj-xxx
FRONTEND_URL=http://localhost:3000
ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================================
# EMAIL (Optional)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ============================================================
# MONITORING (Optional)
# ============================================================
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx